# Copy this file to .env and fill in values before running the server
# Example: copy .env.example .env

# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://sakthiganesh302_db_user:sakthi@cluster0.rmwksyg.mongodb.net/?appName=Cluster0

# AI API key for analysis
# Use one of the following keys:
# - OPENAI_API_KEY for OpenAI
# - GROQ_API_KEY for Groq SDK
# If OPENAI_API_KEY is set, OpenAI is used. If only GROQ_API_KEY is set, Groq is used.
OPENAI_API_KEY=
GROQ_API_KEY=

# JWT secret used to sign auth tokens (recommended to change)
JWT_SECRET=sakthi_super_secure_key_2026

# Optional: URL where the client runs (used for CORS)
CLIENT_URL=http://localhost:5173

# Optional: server port (defaults to 5000)
PORT=5000
