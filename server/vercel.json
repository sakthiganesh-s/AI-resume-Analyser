{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "MONGODB_URI": "@MONGODB_URI",
    "OPENAI_API_KEY": "@OPENAI_API_KEY",
    "GROQ_API_KEY": "@GROQ_API_KEY",
    "JWT_SECRET": "@JWT_SECRET",
    "CLIENT_URL": "@CLIENT_URL",
    "PORT": "5000"
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
